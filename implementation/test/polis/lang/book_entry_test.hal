(ns polis.lang.book-entry-test
  (:require [code.test :refer :all]
            [polis.lang.book-entry :refer :all]))

^{:refer polis.lang.book-entry/book-entry? :added "4.0"}
(fact "checks if object is a book entry"
  (book-entry? (book-entry {})) => true)

^{:refer polis.lang.book-entry/book-entry :added "4.0"}
(fact "creates a book entry"

  ;;
  ;; defn.<> specification
  ;;
  (book-entry {:lang :lua
               :id 'identity-fn
               :module 'L.core
               :section :code
               :form '(defn identity-fn [x] x)
               :form-input '(defn identity-fn [x] x)
               :deps #{}
               :namespace 'L.core
               :declared false})
  => book-entry?

  ;;
  ;; defmacro.<> specification
  ;;
  (book-entry {:lang :lua
               :id 'identity
               :module 'L.core
               :section :fragment
               :form '(defn identity [x] x)
               :form-input '(defn identity [x] x)
               :template (fn [x] x)
               :standalone '(fn [x] (return x))
               :deps #{}
               :namespace 'L.core
               :declared false})
  => book-entry?)
