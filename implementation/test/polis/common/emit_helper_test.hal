(ns polis.common.emit-helper-test
  (:require [code.test :refer :all]
            [polis.common.emit-helper :as helper :refer :all]
            [polis.common.grammar :as grammar]))

(def +reserved+
  (grammar/to-reserved (grammar/build)))

(def +grammar+
  (grammar/grammar :test +reserved+ helper/+default+))

^{:refer polis.common.emit-helper/default-emit-fn :added "4.0"}
(fact "the default emit function"
  (default-emit-fn 'abc {} {}) => "abc")

^{:refer polis.common.emit-helper/pr-single :added "3.0"}
(fact "prints a single quoted string"

  (pr-single "hello")
  => "'hello'"

  (pr-single "he'\"llo")
  => "'he\\'\"llo'"

  (pr-single "''")
  => "'\\'\\''")

^{:refer polis.common.emit-helper/get-option :added "3.0"}
(fact "gets either the path option or the default one"

  (get-option helper/+default+ [:block :for] :sep)
  => ","

  (get-option helper/+default+ [:data :map] :start)
  => "{")

^{:refer polis.common.emit-helper/get-options :added "3.0"}
(fact "gets the path option merged with defaults"

  (get-options helper/+default+ [:data :map])
  => {:statement ";",
      :sep ",",
      :space "",
      :static ".",
      :start "{",
      :line-spacing 1,
      :assign "=",
      :namespace-full "____",
      :apply ".",
      :access ".",
      :end "}",
      :namespace ".",
      :range ":"})

^{:refer polis.common.emit-helper/form-key-base :added "4.0"}
(fact "gets the key for a form"

  (form-key-base :a)
  => [:keyword :token true]

  (form-key-base ())
  => :expression)

^{:refer polis.common.emit-helper/basic-typed-args :added "4.0"}
(fact "typed args without grammar checks"

  (mapv (juxt meta identity)
        (basic-typed-args '(:int i, :const :int j)))
  => '[[{:- [:int]} i]
       [{:- [:const :int]} j]])

^{:refer polis.common.emit-helper/emit-typed-allowed-args :added "4.0"}
(fact "allowed declared args other than symbols"
  (emit-typed-allowed-args [[{:modifiers [:int]}] {:modifiers [:int]}] {:allow {:assign #{:symbol}}})
  => throws)

^{:refer polis.common.emit-helper/emit-typed-args :added "3.0"}
(fact "create types args from declarationns"

  (emit-typed-args '(:int i := 9, :const :int j := 10)
                   +grammar+)
  => '[{:modifiers [:int],
        :symbol i,
        :assign true,
        :force true,
        :value 9}
       {:modifiers [:const :int],
        :symbol j,
        :assign true,
        :force true,
        :value 10}]

  (emit-typed-args '((:int a) 9)
                   +grammar+)
  => '[{:modifiers [], :symbol a, :type (:int), :value 9}]

  (emit-typed-args '(:mutable (:int a) 9)
                    +grammar+)
  => '[{:modifiers [:mutable], :symbol a, :type (:int), :value 9}]

  (emit-typed-args '(a b)
                   +grammar+)
  => '[{:modifiers [], :symbol a}
       {:modifiers [], :symbol b}]

  (emit-typed-args '(a b)
                   +grammar+
                   {:shorthand true})
  => '[{:modifiers [], :symbol a, :value b}]

  (emit-typed-args '(out [])
                   +grammar+
                   {:shorthand true})
  => '[{:modifiers [], :symbol out, :value []}])

^{:refer polis.common.emit-helper/emit-symbol-full :added "4.0"}
(fact "emits a full symbol"

  (emit-symbol-full 'hello 'ns +grammar+)
  => "ns____hello")

^{:refer polis.common.emit-helper/emit-type-record :added "4.0"}
(fact "formats to standard"

  (emit-type-record {:modifiers [:int]
                     :symbol "a"})
  => {:symbol "a", :type "int"})


^{:refer polis.common.emit-helper/rest-arg-form? :added "4.1"}
(fact "recognizes only the canonical final rest argument shape"
  (rest-arg-form? '(:.. args)) => true
  (rest-arg-form? '(:.. "args")) => false
  (rest-arg-form? '(:.. args extra)) => false
  (rest-arg-form? '[:.. args]) => false)

^{:refer polis.common.emit-helper/rest-arg-symbol :added "4.1"}
(fact "returns the symbol from a canonical rest argument"
  (rest-arg-symbol '(:.. args)) => 'args
  (rest-arg-symbol '(:.. "args")) => nil)
