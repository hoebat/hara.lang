(ns polis.common.grammar-test
  (:require [code.test :refer :all]
            [polis.common.grammar :refer :all]
            [polis.common.grammar-spec :as spec]))

^{:refer polis.common.grammar/gen-ops :added "4.0"}
(fact "generates ops"

  (vector? (gen-ops 'polis.common.grammar-spec "spec"))
  => true)

^{:refer polis.common.grammar/normalize-op-entry :added "4.1"}
(fact "normalizes shared macro and hard-link defaults"
  (normalize-op-entry
   {:op :x-add
    :emit :macro
    :macro #'polis.common.grammar-xtalk/tf-add})
  => (contains {:value/template #'polis.common.grammar-xtalk/tf-add
                :value/standalone true})

  (normalize-op-entry
   {:op :prototype-create
    :emit :macro
    :macro #'polis.common.grammar-xtalk/tf-add})
  => (contains {:value/template #'polis.common.grammar-xtalk/tf-add
                :value/standalone true})

  (normalize-op-entry
   {:op :helper
    :emit :hard-link
    :raw 'xt.lang.common-data/obj-keys})
  => (contains {:value/standalone 'xt.lang.common-data/obj-keys}))

^{:refer polis.common.grammar/collect-ops :added "4.0"}
(fact "collects alll ops together"

  (map? (collect-ops +op-categories+))
  => true)

^{:refer polis.common.grammar/ops-list :added "4.0"}
(fact "lists all ops in the grammar"

  (vec (ops-list))
  => [:builtin
      :builtin-global
      :builtin-module
      :builtin-helper
      :free-control
      :free-literal
      :math
      :compare
      :logic
      :counter
      :return
      :throw
      :await
      :async
      :data-table
      :data-shortcuts
      :data-range
      :vars
      :bit
      :pointer
      :fn
      :block
      :control-base
      :control-general
      :control-try-catch
      :top-base
      :top-global
      :class
      :for
      :coroutine
      :prototype
      :functional-core
      :macro
      :macro-arrow
      :macro-let
      :macro-xor
      :macro-case
      :macro-forange
      :xtalk-common
      :xtalk-functional
      :xtalk-language-specific
      :xtalk-hara.lang-link-specific
      :xtalk-runtime-specific])

^{:refer polis.common.grammar/ops-symbols :added "4.0"}
(fact "gets a list of symbols"

  (> (count (vec (ops-symbols))) 0)
  => true)

^{:refer polis.common.grammar/ops-summary :added "4.0"}
(fact "gets the symbol and op name for a given category"

  (ops-summary [:macro])
  => '[[:macro {:tfirst #{->}, :tlast #{->>}, :doto #{doto}, :if #{if}, :cond #{cond}, :when #{when}}]]

  (ops-summary [:counter])
  => [[:counter {:incby #{:+=}, :decby #{:-=}, :mulby #{:*=}, :incto #{:++}, :decto #{:--}}]])

^{:refer polis.common.grammar/ops-detail :added "4.0"}
(fact "get sthe detail of the ops"

  (map? (ops-detail :macro-arrow))
  => true)

^{:refer polis.common.grammar/default-lookup :added "4.1"}
(fact "removes optional categories from the lookup"
  (key-member? (default-lookup +op-all+)
               :functional-core)
  => false

  (key-member? (default-lookup +op-all+)
               :math)
  => true)

^{:refer polis.common.grammar/build :added "4.1"}
(fact "functional core ops are selected explicitly"

  (map? (build :include [:functional-core]))
  => true)

^{:refer polis.common.grammar/build-min :added "4.0"}
(fact "minimum ops example for a language"

  (map? (build-min))
  => true)

^{:refer polis.common.grammar/build-xtalk :added "4.0"}
(fact "xtalk ops"

  (map? (build-xtalk))
  => true)

^{:refer polis.common.grammar/build:override :added "4.0"}
(fact "overrides existing ops in the map"

  (build:override (build-min)
                  {:WRONG {}})
  => (throws)

  (map? (build:override (build-min)
                        {:ret {}}))
  => true)

^{:refer polis.common.grammar/build:extend :added "4.0"}
(fact "adds new  ops in the map"

  (map? (build:extend (build-min)
                      {:NEW {}}))
  => true

  (build:extend (build-min)
                {:ret {}})
  => (throws))

^{:refer polis.common.grammar/to-reserved :added "3.0"}
(fact "convert op map to symbol map"

  (to-reserved (build :include [:vars]))
  => '{:=      {:op :seteq, :symbol #{:=}, :emit :assign, :raw "="},
       var     {:op :var,
                :symbol #{var},
                :emit :def-assign,
                :raw "",
                :assign "="}})

^{:refer polis.common.grammar/grammar-structure :added "3.0"}
(fact "returns all the `:block` and `:fn` forms"

  (grammar-structure (build :include [:vars]))
  => {:block #{}, :def #{}, :fn #{}}


  (grammar-structure (build :include [:control-general]))
  => {:block #{:for :while :branch}, :def #{}, :fn #{}}

  (grammar-structure (build :include [:top-base]))
  => {:block #{},
      :def #{:defn :def :defrun},
      :fn #{}})

^{:refer polis.common.grammar/grammar-sections :added "3.0"}
(fact "process sections witihin the grammar"

  (grammar-sections (build :include [:top-base]))
  => #{:code}

  (grammar-sections (build))
  => #{:code})

^{:refer polis.common.grammar/grammar-macros :added "3.0"}
(fact "process macros within the grammar"

  (grammar-macros (build-min))
  => #{:defn :defglobal :def :defrun})

^{:refer polis.common.grammar/grammar? :added "3.0"}
(fact "checks that an object is instance of grammar"

  (grammar? (grammar :test
              (to-reserved (build))
              {}))
  => true)

^{:refer polis.common.grammar/grammar :added "3.0"
  :style/indent 1}
(fact "constructs a grammar"

  (map? (grammar :test
          (to-reserved (build-min))
          {}))
  => true)
