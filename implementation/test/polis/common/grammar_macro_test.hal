(ns polis.common.grammar-macro-test
  (:require [code.test :refer :all]
            [polis.common.grammar-macro :refer :all]))

^{:refer polis.common.grammar-macro/tf-macroexpand :added "3.0"}
(fact "macroexpands the current form"
  (tf-macroexpand '(-> 1 (inc)))
  => '(inc 1))

^{:refer polis.common.grammar-macro/tf-when :added "3.0"}
(fact "transforms when to a branch"
  (tf-when '(when true :A :B :C))
  => '(br* (if true :A :B :C)))

^{:refer polis.common.grammar-macro/tf-if :added "3.0"}
(fact "transforms if to a branch"
  [(tf-if '(if true :A :B))
   (tf-if '(if true :A))]
  => '[(br* (if true :A) (else :B))
       (br* (if true :A))])

^{:refer polis.common.grammar-macro/tf-cond :added "3.0"}
(fact "transforms cond to a branch"
  [(tf-cond '(cond true :A false :B))
   (tf-cond '(cond true :A false :B :else :C))]
  => '[(br* (if true :A) (elseif false :B))
       (br* (if true :A) (elseif false :B) (else :C))])

^{:refer polis.common.grammar-macro/tf-let-bind :added "4.0"}
(fact "converts let to statements"
  (tf-let-bind '(let [#{x} 1 b 2]
                  (return (+ x b))))
  => '(do* (var #{x} := 1)
           (var b := 2)
           (return (+ x b))))

^{:refer polis.common.grammar-macro/tf-case :added "4.0"}
(fact "transforms case to switch"
  (tf-case '(case (type obj)
              :A (return A)
              :B (return B)
              (return X)))
  => '(switch
       [(type obj)]
       (case [:A] (return A))
       (case [:B] (return B))
       (default (return X))))

^{:refer polis.common.grammar-macro/tf-lambda-arrow :added "4.0"}
(fact "transforms generalized lambdas"
  [(tf-lambda-arrow '(fn:> [e] e))
   (tf-lambda-arrow '(fn:> [e] (return e)))]
  => '[(fn [e] (return e))
       (fn [e] (return e))])

^{:refer polis.common.grammar-macro/tf-tcond :added "4.0"}
(fact "transforms ternary cond"
  (tf-tcond '(:?> :a a :b b :else c))
  => '(:? :a [a (:? :b [b c])]))

^{:refer polis.common.grammar-macro/tf-xor :added "4.0"}
(fact "transforms xor"
  (tf-xor '(xor a b))
  => '(== (not (not a)) (not (not b))))

^{:refer polis.common.grammar-macro/tf-doto :added "4.0"}
(fact "transforms doto"
  (tf-doto '(doto sym
              (. a)
              (b)
              (. c)))
  => '(do (. sym a) (b sym) (. sym c)))

^{:refer polis.common.grammar-macro/tf-do-arrow :added "4.0"}
(fact "transforms do arrow"
  (tf-do-arrow '(do:> 1 2 (return 3)))
  => '((fn [] 1 2 (return 3))))

^{:refer polis.common.grammar-macro/tf-forange :added "4.0"}
(fact "creates forange forms"
  [(tf-forange '(forange [i 10] (print i)))
   (tf-forange '(forange [i [10 3 -2]] (print i)))]
  => '[(for [(var i 0) (< i 10) [(:= i (+ i 1))]] (print i))
       (for [(var i 10) (< i 3) [(:= i (- i 2))]] (print i))])

^{:refer polis.common.grammar-macro/+op-macro+ :added "4.0"}
(fact "loads macro operator specifications"
  [(count +op-macro+)
   (:op (first +op-macro-arrow+))
   (:op (first +op-macro-let+))
   (:op (first +op-macro-case+))
   (:op (first +op-macro-forange+))]
  => [6 :dofn :let-bind :switch :forange])
