(ns polis.common.provenance-test
  (:require [code.test :refer :all]
            [polis.common.provenance :refer :all]))

^{:refer polis.common.provenance/module-id :added "4.1"}
(fact "extracts module ids from maps and symbols"
  [(module-id {:id 'demo.core})
   (module-id 'demo.core)]
  => '[demo.core demo.core])

^{:refer polis.common.provenance/namespace-id :added "4.1"}
(fact "normalizes namespace references"
  [(namespace-id 'polis.common.provenance-test)
   (namespace-id 'demo.core)]
  => '[polis.common.provenance-test demo.core])

^{:refer polis.common.provenance/line-of :added "4.1"}
(fact "finds line metadata across nested values"
  (let [form (protocol-call IObjType with-meta '(+ 1 2) {:line 12})]
    [(line-of nil)
     (line-of form)
     (line-of {:form form})])
  => [nil 12 12])

^{:refer polis.common.provenance/compact :added "4.1"}
(fact "drops nil values from maps"
  (compact {:a 1 :b nil :c 3})
  => '{:a 1 :c 3})

^{:refer polis.common.provenance/frame :added "4.1"}
(fact "builds a compact provenance frame"
  (let [form (protocol-call IObjType with-meta '(boom 1) {:line 33})]
    (frame {:polis/provenance {:polis/phase :emit/form}
            :polis/subsystem :probe/op
            :polis/module {:id 'demo.core}
            :polis/namespace 'polis.common.provenance-test
            :polis/form form}))
  => '{:polis/phase :emit/form
       :polis/subsystem :probe/op
       :polis/module demo.core
       :polis/namespace polis.common.provenance-test
       :polis/line 33
       :polis/form (boom 1)})

^{:refer polis.common.provenance/provenance :added "4.1"}
(fact "merges provenance inputs into a single frame"
  (provenance {:polis/module 'demo.core}
              {:polis/line 10}
              {:polis/subsystem :emit/direct})
  => '{:polis/module demo.core
       :polis/line 10
       :polis/subsystem :emit/direct})

^{:refer polis.common.provenance/provenance-stack :added "4.1"}
(fact "returns stack frames from explicit stacks or a single frame"
  [(provenance-stack {:polis/provenance-stack [{:polis/module 'demo.core}
                                               {:polis/module 'demo.next}]})
   (provenance-stack {:polis/module 'demo.core})]
  => '[[{:polis/module demo.core}
        {:polis/module demo.next}]
       [{:polis/module demo.core}]])

^{:refer polis.common.provenance/same-site? :added "4.1"}
(fact "compares provenance frames by site fields"
  [(same-site? {:polis/phase :emit/form
                :polis/subsystem :probe
                :polis/module 'demo.core
                :polis/line 10}
               {:polis/phase :emit/form
                :polis/subsystem :probe
                :polis/module 'demo.core
                :polis/line 10
                :polis/form '(ignored)})
   (same-site? {:polis/phase :emit/form}
               {:polis/phase :emit/direct})]
  => [true false])

^{:refer polis.common.provenance/append-frame :added "4.1"}
(fact "appends only distinct provenance sites"
  [(append-frame [{:polis/phase :emit/form}] {:polis/phase :emit/form})
   (append-frame [{:polis/phase :emit/form}] {:polis/phase :emit/direct})]
  => '[[{:polis/phase :emit/form}]
       [{:polis/phase :emit/form}
        {:polis/phase :emit/direct}]])

^{:refer polis.common.provenance/with-provenance :added "4.1"}
(fact "threads merged provenance into mopts"
  (with-provenance {:lang :lua}
                   {:polis/module 'demo.core}
                   {:polis/line 10})
  => '{:lang :lua
       :polis/provenance {:polis/module demo.core
                         :polis/line 10}})

^{:refer polis.common.provenance/error-with-provenance :added "4.1"}
(fact "wraps throwables with merged provenance data"
  (try
    (throw (ex-info "inner"
                    {:inner true
                     :polis/provenance {:polis/phase :emit/form
                                       :polis/module 'demo.inner}}))
    (catch Throwable t
      (let [wrapped (error-with-provenance
                     "wrap"
                     {:outer true
                      :polis/phase :emit/direct
                      :polis/module 'demo.outer}
                     t)]
        [(ex-message wrapped)
         (select-keys (ex-data wrapped)
                      [:inner
                       :outer
                       :polis/phase
                       :polis/module
                       :polis/wrapped
                       :polis/cause-message])])))
  => '["wrap: inner"
       {:inner true
        :outer true
        :polis/phase :emit/form
        :polis/module demo.inner
        :polis/wrapped true
        :polis/cause-message "inner"}])

^{:refer polis.common.provenance/throw-with-provenance :added "4.1"}
(fact "throws wrapped provenance exceptions"
  (try
    (throw (ex-info "inner" {:inner true}))
    (catch Throwable t
      (try
        (throw-with-provenance "wrap" {:outer true} t)
        (catch Throwable wrapped
          [(ex-message wrapped)
           (:outer (ex-data wrapped))]))))
  => ["wrap: inner" true])
