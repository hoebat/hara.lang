(ns polis.common.preprocess-base-test
  (:require [code.test :refer :all]
            [polis.common.preprocess-base
             :refer :all
             :refer-macros [with:macro-opts]]))

^{:refer polis.common.preprocess-base/macro-form :added "4.1"}
(fact "gets the current macro form"
  (binding [polis.common.preprocess-base/*macro-form* 'hello]
    (macro-form))
  => 'hello)

^{:refer polis.common.preprocess-base/macro-opts :added "4.1"}
(fact "gets current macro options"
  (binding [polis.common.preprocess-base/*macro-opts* {:a 1}]
    (macro-opts))
  => {:a 1})

^{:refer polis.common.preprocess-base/macro-grammar :added "4.1"}
(fact "gets the current grammar"
  (binding [polis.common.preprocess-base/*macro-grammar* {:a 1}]
    (macro-grammar))
  => {:a 1})

(fact "binds macro options"
  (with:macro-opts [{:a 1}]
    (macro-opts))
  => {:a 1})
