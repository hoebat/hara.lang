(ns polis.common.book-meta-test
  (:require [code.test :refer :all]
            [polis.common.util :as ut]
            [polis.common.book-meta :refer :all]))

^{:refer polis.common.book-meta/book-meta? :added "4.0"}
(fact "checks if object is a book meta"
  (book-meta? (book-meta {})) => true)

^{:refer polis.common.book-meta/book-meta :added "4.0"}
(fact "creates a book meta"

  (book-meta {:module-export (fn [{:keys [as]} opts]
                              (list 'return as))
              :module-import (fn [name {:keys [as]} opts]
                               (list 'var as ':= (list 'require (str name))))
              :has-ptr (fn [ptr]
                         (list 'not= (ut/sym-full ptr) nil))
              :teardown-ptr (fn [ptr]
                              (list ':= (ut/sym-full ptr) nil))})
  => book-meta?)
