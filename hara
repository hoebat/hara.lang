#!/bin/bash

# Resolve the directory where this script is located
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"

HARA_RUNTIME_JAR="${HARA_RUNTIME_JAR:-$SCRIPT_DIR/target/hara-truffle.jar}"

if [[ ! -r "$HARA_RUNTIME_JAR" ]]; then
    echo "Hara runtime JAR not found: $HARA_RUNTIME_JAR" >&2
    echo "Build it once with: mvn -Ptruffle -DskipTests package" >&2
    exit 1
fi

exec java -jar "$HARA_RUNTIME_JAR" "$@"
