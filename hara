#!/bin/bash

# Check if Maven is installed
if ! command -v mvn &> /dev/null
then
    echo "mvn could not be found. Please install Maven."
    exit 1
fi

# Resolve the directory where this script is located
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"

# Run the hara.kernel.Main class using Maven
# -f points to the pom.xml in the script's directory
# -q suppresses Maven output
mvn -q -f "$SCRIPT_DIR/pom.xml" compile exec:java -Dexec.mainClass="hara.kernel.Main" -Dexec.args="$*"
