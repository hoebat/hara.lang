(ns polis.common.grammar-spec-test
  (:require [code.test :refer :all]
            [polis.common.grammar-spec :refer :all]))

(defn mixin-add-symbol
  [value]
  {:symbol polis.common.grammar-spec/*symbol*
   :base (:base value)})

^{:refer polis.common.grammar-spec/get-comment :added "4.0"}
(fact "gets the comment access prefix"
  (get-comment {:default {:comment {:prefix "//"}}} {})
  => "//")

^{:refer polis.common.grammar-spec/format-fargs :added "3.0"}
(fact "formats function inputs"
  [(format-fargs '[[a b]])
   (format-fargs '["docstring" [a b]])
   (format-fargs '(([a] a)
                   ([a b] (+ a b))))]
  => '[["" {} ([a b])]
       ["docstring" {} ([a b])]
       ["" {} (([a] a)
               ([a b] (+ a b)))]])

^{:refer polis.common.grammar-spec/format-defn-mixins :added "4.1"}
(fact "applies portable mixins in order"
  (binding [polis.common.grammar-spec/*symbol* 'hello]
    [(format-defn-mixins
      {:base true}
      ['polis.common.grammar-spec-test/mixin-add-symbol])
     (format-defn-mixins
      {:base true}
      ['(hash-map :from-form *symbol*)])
     (format-defn-mixins
      {:base true}
      ['{:from-map true}])])
  => '[{:symbol hello
        :base true}
       {:from-form hello}
       {:base true
        :from-map true}])

^{:refer polis.common.grammar-spec/format-defn :added "3.0"}
(fact "standardizes defn forms"
  (let [result (format-defn '(defn hello "hello" {:list 1} []))]
    [(first result)
     (str (second result))])
  => '[{:list 1 :doc "hello"}
       "(defn hello [])"])

^{:refer polis.common.grammar-spec/tf-for-index :added "4.0"}
(fact "transforms indexed loops"
  [(tf-for-index '(for:index [i [0 2 3]]))
   (tf-for-index '(for:index [i [0 2 -1]]))]
  => '[(for [(var i := 0) (< i 2) (:= i (+ i 3))])
       (for [(var i := 0) (> i 2) (:= i (+ i -1))])])

^{:refer polis.common.grammar-spec/+op-builtin+ :added "4.0"}
(fact "loads portable operator specification data"
  [(count +op-builtin+)
   (:op (first +op-math+))
   (:symbol (first +op-control-general+))
   (str (:format (first +op-top-base+)))]
  => '[11 :add #{for} "#'polis.common.grammar-spec/format-defn"])
