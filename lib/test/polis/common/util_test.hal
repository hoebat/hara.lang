(ns polis.common.util-test
  (:require [code.test :refer :all]
            [polis.common.util :refer :all]
            [std.lib.context :as context]))

^{:refer polis.common.util/sym-id :added "3.0"}
(fact "gets the symbol id"
  (sym-id 'L.core/identity)
  => 'identity)

^{:refer polis.common.util/sym-module :added "3.0"}
(fact "gets the symbol namespace"
  (sym-module 'L.core/identity)
  => 'L.core)

^{:refer polis.common.util/sym-pair :added "3.0"}
(fact "gets the symbol pair"
  (sym-pair 'L.core/identity)
  => '[L.core identity])

^{:refer polis.common.util/sym-full :added "3.0"}
(fact "creates a full symbol"
  [(sym-full 'L.core 'identity)
   (sym-full {:module 'L.core :id 'identity})]
  => '[L.core/identity L.core/identity])

^{:refer polis.common.util/sym-default-str :added "4.0"}
(fact "converts symbols to default target spelling"
  [(sym-default-str :helloWorld)
   (sym-default-str :hello-World)]
  => ["helloWorld" "hello_World"])

^{:refer polis.common.util/sym-default-inverse-str :added "4.0"}
(fact "restores Hara symbol spelling"
  (sym-default-inverse-str "hello_world")
  => "hello-world")

^{:refer polis.common.util/hashvec? :added "4.0"}
(fact "checks for hash vectors"
  [(hashvec? #{[1 2 3]})
   (hashvec? #{1})]
  => [true false])

^{:refer polis.common.util/doublevec? :added "4.0"}
(fact "checks for double vectors"
  [(doublevec? [[1 2 3]])
   (doublevec? [1 2 3])]
  => [true false])

^{:refer polis.common.util/lang-context :added "4.0"}
(fact "creates language context keys"
  (lang-context :lua)
  => :lang/lua)

^{:refer polis.common.util/lang-rt-list :added "4.0"}
(fact "lists runtimes in a namespace"
  (lang-rt-list)
  => [])

^{:refer polis.common.util/lang-rt :added "4.0"}
(fact "returns runtimes in a map"
  (lang-rt)
  => {})

^{:refer polis.common.util/lang-pointer :added "4.0"}
(fact "creates language pointers"
  (let [pointer (lang-pointer :lua {:module 'L.core})]
    [(context/pointer? pointer)
     (:context pointer)
     (:module pointer)
     (:lang pointer)])
  => '[true :lang/lua L.core :lua])

^{:refer polis.common.util/lang-rt-default :added "4.0"}
(fact "selects a default runtime"
  (context/rt-null?
   (lang-rt-default (lang-pointer :lua {:module 'L.core})))
  => true)

^{:refer polis.common.util/module-id :added "4.1"}
(fact "gets module ids from maps and symbols"
  [(module-id {:id 'L.core})
   (module-id 'L.core)]
  => '[L.core L.core])

^{:refer polis.common.util/entry-summary :added "4.1"}
(fact "returns concise entry summaries"
  (entry-summary {:lang :lua
                  :module 'L.core
                  :namespace 'L.core
                  :id 'add
                  :section :fragment
                  :line 10
                  :op 'def$
                  :op-key :def$})
  => '{:op-key :def$
       :symbol L.core/add
       :section :fragment
       :op def$
       :module L.core
       :lang :lua
       :line 10
       :id add
       :namespace L.core})

^{:refer polis.common.util/error-with-context :added "4.1"}
(fact "wraps exceptions with Polis context"
  (try
    (throw (ex-info "inner" {:inner true}))
    (catch Throwable throwable
      (let [wrapped (error-with-context "wrap" {:outer true} throwable)]
        [(ex-message wrapped)
         (:inner (ex-data wrapped))
         (:outer (ex-data wrapped))
         (:polis/wrapped (ex-data wrapped))])))
  => ["wrap: inner" true true true])

^{:refer polis.common.util/throw-with-context :added "4.1"}
(fact "throws wrapped exceptions with Polis context"
  (try
    (throw (ex-info "inner" {:inner true}))
    (catch Throwable throwable
      (try
        (throw-with-context "wrap" {:outer true} throwable)
        (catch Throwable wrapped
          [(ex-message wrapped)
           (:outer (ex-data wrapped))]))))
  => ["wrap: inner" true])
