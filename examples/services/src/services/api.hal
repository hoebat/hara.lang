(ns services.api
  (:require [services.worker :as worker]
            [std.lib.string :as string]))

(defn normalize-route
  "Normalizes a route received at the service boundary."
  [route]
  (string/to-lower (string/trim route)))

(defn dispatch
  "Dispatches a job to the worker and returns a persistent response map."
  [route job]
  {:route (normalize-route route)
   :result (worker/process-job job)})
