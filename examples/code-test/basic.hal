(ns example.code-test.basic
  (:require [code.test :refer :all]))

(fact "adds numbers"
  (+ 2 3) => 5)

(fact "counts collections"
  (count ["hara" "truffle" "test"]) => 3)

(fact "checks map lookup"
  (get {:status :ready} :status) => :ready)

(code.test/run {:namespace "example.code-test.basic"})
