    "same-changed": [
      {
        "clojure": "map",
        "dimensions": [
          "arity",
          "evaluation",
          "return-type"
        ],
        "hara": "map",
        "summary": "Direct calls are lazy in both; Hara's one-argument transform is eager on ordinary collections and returns a vector, while preserving arrays and existing lazy sources."
      },
      {
        "clojure": "seq",
        "dimensions": [
          "accepted-inputs",
          "arity",
          "return-type"
        ],
        "hara": "seq",
        "summary": "Hara exposes the iterator boundary explicitly and also supports applying a transform lazily as (seq transform source); it does not require Clojure ISeq."
      },
      {
        "clojure": "rest",
        "dimensions": [
          "empty-value",
          "return-type"
        ],
        "hara": "rest",
        "summary": "Hara returns nil when no values remain; Clojure rest returns an empty sequence."
      },
      {
        "clojure": "partition",
        "dimensions": [
          "arity",
          "evaluation",
          "return-type"
        ],
        "hara": "partition",
        "summary": "Hara direct calls are lazy, while its one-argument transform is eager and returns a vector (or array for array input); Clojure's one-argument form is a transducer."
      },
      {
        "clojure": "partition-all",
        "dimensions": [
          "arity",
          "evaluation",
          "return-type"
        ],
        "hara": "partition-all",
        "summary": "Hara's one-argument form is an eager transform rather than a Clojure transducer."
      },
      {
        "clojure": "keys",
        "dimensions": [
          "return-type"
        ],
        "hara": "keys",
        "summary": "Hara returns its runtime-neutral lazy Seq rather than Clojure's JVM sequence implementation."
      },
      {
        "clojure": "vals",
        "dimensions": [
          "return-type"
        ],
        "hara": "vals",
        "summary": "Hara returns its runtime-neutral lazy Seq rather than Clojure's JVM sequence implementation."
      },
      {
        "clojure": "some",
        "dimensions": [
          "name",
          "return-value"
        ],
        "hara": "any?",
        "summary": "Hara any? returns a boolean existential result; Clojure some returns the first truthy predicate result."
      },
      {
        "clojure": "empty?",
        "dimensions": [
          "accepted-inputs",
          "evaluation"
        ],
        "hara": "empty?",
        "summary": "Hara checks through the iterator protocol and may inspect a one-shot iterator; Clojure uses seq semantics."
      },
      {
        "clojure": "let",
        "dimensions": [
          "binding-evaluation"
        ],
        "hara": "let",
        "summary": "Hara evaluates initializers against the enclosing lexical environment in parallel; Clojure let bindings are sequential."
      },
      {
        "clojure": "defrecord",
        "dimensions": [
          "host-types",
          "interop",
          "implementation"
        ],
        "hara": "defrecord",
        "summary": "Hara has no Clojure JVM record/class contract; portable immutable domain values use defstruct and protocols."
      },
      {
        "clojure": "eval",
        "dimensions": [
          "host",
          "capability",
          "environment"
        ],
        "hara": "eval",
        "summary": "Hara evaluates through its context-local language runtime and does not expose Clojure compiler/JVM eval semantics."
      }
    ],
