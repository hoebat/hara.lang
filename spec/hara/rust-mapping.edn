 :collection-implementation :im-rc
 :x-symbols :polyglot-only
 :surfaces
 [{:id :reader :rust :reader :acceptance :reader}
  {:id :evaluator :rust :evaluator :acceptance :compiler-runtime}
  {:id :persistent-values :rust :value-enum :acceptance :collection}
  {:id :protocols :rust :protocol-registry :acceptance :protocol}
  {:id :iterators :rust :closeable-iterator :acceptance :iterator}
  {:id :promises :rust :promise-provider :acceptance :generated-libraries}
  {:id :bytes :rust :byte-buffer :acceptance :mutable-boundary}
  {:id :markers :rust :mutable-handles :acceptance :mutable-boundary}
  {:id :files :rust :file-provider :acceptance :capability}
  {:id :sockets :rust :socket-provider :acceptance :capability}
  {:id :native-flavors :rust :provider-registry :acceptance :native-flavor}]}
