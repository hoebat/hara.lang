#!/usr/bin/env bash

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

mvn -B -f "$ROOT/java/pom.xml" -Ptruffle -DskipTests test-compile dependency:copy-dependencies \
  -DincludeScope=runtime \
  -DoutputDirectory="$ROOT/java/target/truffle-dependencies"

exec java \
  -cp "$ROOT/java/target/test-classes:$ROOT/java/target/classes:$ROOT/java/target/truffle-dependencies/*" \
  hara.truffle.HaraWasmTruffleParityBenchmark "$@"
