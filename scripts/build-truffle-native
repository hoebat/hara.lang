#!/usr/bin/env bash

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEPENDENCIES="$ROOT/java/target/truffle-dependencies"

cd "$ROOT"

mvn -f "$ROOT/java/pom.xml" -Ptruffle -DskipTests clean compile dependency:copy-dependencies \
  -DincludeScope=runtime \
  -DoutputDirectory="$DEPENDENCIES"

NATIVE_IMAGE_OPTIONS=(--no-fallback)
if native-image --help 2>&1 | grep -q -- '--emit'; then
  NATIVE_IMAGE_OPTIONS+=(--emit=build-report)
fi
if [[ "${HARA_NATIVE_USE_FALLBACK_RUNTIME:-false}" == "true" ]]; then
  NATIVE_IMAGE_OPTIONS+=(-Dtruffle.UseFallbackRuntime=true)
fi

native-image \
  "${NATIVE_IMAGE_OPTIONS[@]}" \
  -cp "$ROOT/java/target/classes:$DEPENDENCIES/*" \
  -H:Class=hara.truffle.Main \
  --initialize-at-build-time=hara.truffle.HaraFunctionGen,hara.truffle.HaraBoxGen,hara.truffle.HaraNullGen,hara.truffle.HaraVarGen,hara.truffle.HaraProtocolGen,hara.truffle.HaraStructGen,hara.truffle.HaraTypeGen,hara.truffle.HaraMemberNamesGen,hara.truffle.HaraHashEntryGen,hara.truffle.HaraMultiFunctionGen,hara.truffle.HaraDecimalGen,hara.truffle.HaraBigIntegerGen,hara.truffle.HaraIteratorGen \
  -o "$ROOT/target/hara-truffle"

echo "Built $ROOT/target/hara-truffle"
